# LLM
LIAISON_LLM_PROVIDER=bedrock
LIAISON_LLM_MODEL_PRIMARY=anthropic.claude-3-5-sonnet-20241022-v2:0
LIAISON_LLM_MODEL_FALLBACK=anthropic.claude-3-5-haiku-20241022-v1:0
LIAISON_LLM_API_BASE=
LIAISON_LLM_API_KEY=

# Base metier (connecteur SQL)
LIAISON_SQL_DSN=postgresql+psycopg://liaison:liaison@postgres:5432/businessdb
LIAISON_SQL_READONLY=true

# Connecteur API (mock ERP/CRM)
LIAISON_ERP_BASE_URL=http://mock-erp:9000

# Connecteur GED (Qdrant — vide = mode demo InMemory)
LIAISON_QDRANT_URL=
LIAISON_QDRANT_COLLECTION=liaison

# Observabilite
LIAISON_LANGFUSE_HOST=http://langfuse:3000
LIAISON_LANGFUSE_PUBLIC_KEY=
LIAISON_LANGFUSE_SECRET_KEY=

# Securite
LIAISON_API_KEYS=dev-key-viewer:viewer,dev-key-operator:operator
LIAISON_RATE_LIMIT_MAX_REQUESTS=60
LIAISON_RATE_LIMIT_WINDOW_SEC=60

# App
LIAISON_LOG_LEVEL=INFO
LIAISON_ENV=local
